#!/bin/bash
# SPDX-License-Identifier: Apache-2.0
# SPDX-FileCopyrightText: Caspar Water Company
#
# duckpond-emergency - Emergency file extraction from DuckPond backups
#                      (D5.7b Delta-Lake-native backup format)
#
# This script extracts files from DuckPond remote backups using only
# DuckDB - no pond binary required.  Use it for disaster recovery
# when the pond software is unavailable.
#
# REQUIREMENTS:
#   - DuckDB CLI (https://duckdb.org/)
#   - b3sum for BLAKE3 verification (optional but recommended)
#   - xxd (for binary extraction; ships with vim/most distros)
#
# USAGE:
#   duckpond-emergency <backup-path> list
#   duckpond-emergency <backup-path> info
#   duckpond-emergency <backup-path> extract <pattern> [out-dir]
#   duckpond-emergency <backup-path> verify [pattern]
#   duckpond-emergency <backup-path> export-all <out-dir>
#
# BACKUP PATH:
#   Local:  /path/to/backup     (or file:///path/to/backup)
#   S3:     s3://bucket/path    (set AWS_* env vars first)
#
# S3/MinIO SETUP (export before invoking):
#   export AWS_ENDPOINT_URL="http://localhost:9000"
#   export AWS_REGION="us-east-1"
#   export AWS_ACCESS_KEY_ID="..."
#   export AWS_SECRET_ACCESS_KEY="..."
#
# IMPLEMENTATION NOTES
# --------------------
#
#   1. STORAGE FORMAT (D5.x):
#      The backup is a Delta Lake table partitioned by partition_kind,
#      laid out on disk / in S3 as:
#
#        <backup>/_delta_log/*.json
#        <backup>/partition_kind=manifest/*.parquet  -- one row per source-pond txn_seq
#        <backup>/partition_kind=checksum/*.parquet  -- per-partition content checksums
#        <backup>/partition_kind=data/*.parquet      -- file add/remove rows w/ chunk bytes
#
#      Each `data` Add row carries one chunk of one source-pond storage file:
#
#        file_path      -- source-pond storage path (e.g.
#                          "_delta_log/00000000000000000001.json",
#                          "pond_id=<u>/part_id=<v>/part-*.parquet",
#                          "_large_files/<hash>")
#        file_action    -- "add" or "remove"
#        file_size      -- total file size in bytes
#        file_blake3    -- BLAKE3 of the complete file
#        chunk_count    -- number of chunks for this file
#        chunk_id       -- 0-based chunk index
#        chunk_data     -- raw chunk bytes (BLOB)
#        chunk_blake3   -- BLAKE3 of chunk_data
#        txn_seq        -- source-pond transaction sequence this row belongs to
#
#      For multi-chunk files (file_size > CHUNK_SIZE_BYTES, 16 MiB), there is
#      one Add row per chunk; concatenating chunk_data in chunk_id order
#      reconstructs the original file byte-for-byte.
#
#      The "current snapshot" of the backup is: for every file_path, the
#      latest action by txn_seq; if it is "add", the file exists; if it is
#      "remove", the file has been deleted.
#
#   2. WHY read_parquet() INSTEAD OF delta_scan():
#      DuckDB's `delta_scan()` goes through DeltaKernel which ignores DuckDB's
#      configured `s3_*` settings and tries the EC2 IMDS endpoint -- that's a
#      no-go for MinIO / non-AWS S3.  Reading the parquet partitions directly
#      via `read_parquet('s3://.../partition_kind=*/*.parquet',
#      hive_partitioning=true)` honours `s3_*` settings and is what we want.
#
#      For freshly-pushed backups (no Vacuum, no removed files) the row set
#      is equivalent to `delta_scan()`.  We also filter by latest txn_seq per
#      file_path so removed files are excluded from list/extract.
#
#   3. BLOB EXTRACTION:
#      DuckDB's portable cross-version way to extract raw bytes from a BLOB
#      column is `SELECT hex(blob_col)` plus `xxd -r -p` on the way out.
#      `COPY (...) TO 'file' (FORMAT BLOB)` is unreliable across versions.

set -u  # error on undefined vars; do NOT use -e here so loops handle errors

VERSION="2.0.0"
SCRIPT_NAME="duckpond-emergency"

# Colors for output (disabled if stdout isn't a tty)
if [ -t 1 ]; then
    RED=$'\033[0;31m'
    GREEN=$'\033[0;32m'
    YELLOW=$'\033[1;33m'
    BLUE=$'\033[0;34m'
    NC=$'\033[0m'
else
    RED=""; GREEN=""; YELLOW=""; BLUE=""; NC=""
fi

log_info()    { echo "${BLUE}[INFO]${NC} $1"; }
log_success() { echo "${GREEN}[OK]${NC} $1"; }
log_warn()    { echo "${YELLOW}[WARN]${NC} $1"; }
log_error()   { echo "${RED}[ERROR]${NC} $1" >&2; }

usage() {
    cat << EOF
$SCRIPT_NAME v$VERSION - Emergency file extraction from DuckPond backups

USAGE:
    $SCRIPT_NAME <backup-path> <command> [args...]

COMMANDS:
    list                    List current-snapshot files in the backup
    info                    Show backup metadata summary
    extract <pat> [dir]     Extract files matching SQL LIKE pattern to dir
    verify [pat]            Verify BLAKE3 of files matching pattern
    export-all <dir>        Export every current-snapshot file to dir

PATTERN (SQL LIKE):  % = any chars, _ = single char.  Anchored to file_path.

OPTIONS:
    -h, --help             Show this help
    -v, --version          Show version

BACKUP PATH:
    Local:  /path/to/backup or file:///path/to/backup
    S3:     s3://bucket/path (set AWS_* env vars first)

EXAMPLES:
    # List files in current snapshot
    $SCRIPT_NAME /backup list

    # Show summary
    $SCRIPT_NAME /backup info

    # Extract only Delta log files
    $SCRIPT_NAME /backup extract '_delta_log/%' ./out/

    # Extract one specific storage parquet
    $SCRIPT_NAME /backup extract 'pond_id=abc%' ./out/

    # Verify all checksums in the current snapshot
    $SCRIPT_NAME /backup verify

    # Reconstruct the source-pond storage tree
    $SCRIPT_NAME /backup export-all ./recovered/

S3/MINIO SETUP:
    export AWS_ENDPOINT_URL="http://localhost:9000"
    export AWS_REGION="us-east-1"
    export AWS_ACCESS_KEY_ID="your-key"
    export AWS_SECRET_ACCESS_KEY="your-secret"
    $SCRIPT_NAME s3://bucket/backup list
EOF
    exit 0
}

check_duckdb() {
    if ! command -v duckdb &>/dev/null; then
        log_error "DuckDB is not installed.  Install from https://duckdb.org/"
        exit 1
    fi
}

check_xxd() {
    if ! command -v xxd &>/dev/null; then
        log_error "xxd is required (provides hex<->binary conversion)."
        exit 1
    fi
}

# Build a DuckDB SQL preamble that configures S3 access if needed.
# Echoes the SQL on stdout; safe to inline in a -c argument.
build_duckdb_preamble() {
    local backup_path="$1"

    if [[ "$backup_path" == s3://* ]]; then
        printf "INSTALL httpfs; LOAD httpfs;\n"

        if [ -n "${AWS_REGION:-}" ]; then
            printf "SET s3_region='%s';\n" "$AWS_REGION"
        else
            printf "SET s3_region='us-east-1';\n"
        fi

        if [ -n "${AWS_ENDPOINT_URL:-}" ]; then
            local endpoint="${AWS_ENDPOINT_URL#http://}"
            endpoint="${endpoint#https://}"
            printf "SET s3_endpoint='%s';\n" "$endpoint"
            printf "SET s3_url_style='path';\n"
            if [[ "$AWS_ENDPOINT_URL" == http://* ]]; then
                printf "SET s3_use_ssl=false;\n"
            fi
        fi

        if [ -n "${AWS_ACCESS_KEY_ID:-}" ]; then
            printf "SET s3_access_key_id='%s';\n" "$AWS_ACCESS_KEY_ID"
        fi
        if [ -n "${AWS_SECRET_ACCESS_KEY:-}" ]; then
            printf "SET s3_secret_access_key='%s';\n" "$AWS_SECRET_ACCESS_KEY"
        fi
    fi
}

# Build the parquet glob for the data partition.
data_glob() {
    local backup_path="${1%/}"  # strip trailing slash
    echo "${backup_path}/partition_kind=data/*.parquet"
}

# Build the parquet glob across all three partitions.
all_glob() {
    local backup_path="${1%/}"
    echo "${backup_path}/partition_kind=*/*.parquet"
}

# Common CTE that resolves the current snapshot from the raw data
# partition.  Defines a view 'snapshot' over file_path/file_size/
# file_blake3/chunk_count for every file whose latest action is 'add'.
# (Used inline in WITH ... AS (...) constructions.)
snapshot_cte() {
    local glob="$1"
    cat <<EOF
WITH per_file AS (
    SELECT
        file_path,
        file_action,
        file_size,
        file_blake3,
        chunk_count,
        txn_seq,
        ROW_NUMBER() OVER (PARTITION BY file_path ORDER BY txn_seq DESC) AS rn
    FROM read_parquet('${glob}', hive_partitioning=true)
    WHERE chunk_id = 0  -- one synthesis row per (file_path, txn_seq)
),
snapshot AS (
    SELECT file_path, file_size, file_blake3, chunk_count, txn_seq
    FROM per_file
    WHERE rn = 1 AND file_action = 'add'
)
EOF
}

#############################
# COMMANDS
#############################

cmd_list() {
    local backup_path="$1"
    local preamble
    preamble=$(build_duckdb_preamble "$backup_path")
    local glob
    glob=$(data_glob "$backup_path")

    log_info "Current-snapshot files in backup: $backup_path"
    echo ""

    duckdb -c "
${preamble}
$(snapshot_cte "$glob")
SELECT
    file_path,
    file_size AS size_bytes,
    chunk_count AS chunks,
    txn_seq AS added_in_txn,
    hex(file_blake3) AS blake3_hex
FROM snapshot
ORDER BY file_path;
"
}

cmd_info() {
    local backup_path="$1"
    local preamble
    preamble=$(build_duckdb_preamble "$backup_path")
    local data
    data=$(data_glob "$backup_path")
    local all
    all=$(all_glob "$backup_path")

    log_info "Backup info: $backup_path"
    echo ""

    echo "=== Current-snapshot summary ==="
    duckdb -c "
${preamble}
$(snapshot_cte "$data")
SELECT
    COUNT(*)              AS live_files,
    COALESCE(SUM(file_size), 0) AS total_bytes,
    COALESCE(SUM(chunk_count), 0) AS total_chunks,
    MIN(txn_seq)          AS earliest_add_txn,
    MAX(txn_seq)          AS latest_add_txn
FROM snapshot;
"

    echo ""
    echo "=== Per-partition row counts ==="
    duckdb -c "
${preamble}
SELECT partition_kind, COUNT(*) AS rows
FROM read_parquet('${all}', hive_partitioning=true)
GROUP BY partition_kind
ORDER BY partition_kind;
"

    echo ""
    echo "=== Source-pond commits (manifest partition) ==="
    duckdb -c "
${preamble}
SELECT
    txn_seq,
    commit_kind,
    parent_seq,
    make_timestamp(ts_micros) AS ts
FROM read_parquet('${all}', hive_partitioning=true)
WHERE partition_kind = 'manifest'
ORDER BY txn_seq;
"
}

# Extract one file from the backup.
#   $1 = SQL preamble
#   $2 = data partition glob
#   $3 = file_path (exact)
#   $4 = output filename
#   $5 = expected file_size (for sanity check)
#   $6 = expected chunk_count
# Echoes "OK" / "FAIL: <reason>" on stdout.
extract_one_file() {
    local preamble="$1"
    local glob="$2"
    local file_path="$3"
    local out_file="$4"
    local expect_size="$5"
    local expect_chunks="$6"

    mkdir -p "$(dirname "$out_file")"
    rm -f "$out_file"
    touch "$out_file"

    # Determine the latest add for this file (we want the snapshot version).
    local add_txn
    add_txn=$(duckdb -noheader -csv -c "
${preamble}
$(snapshot_cte "$glob")
SELECT txn_seq FROM snapshot WHERE file_path = '${file_path}';
" 2>/dev/null | tr -d ' \r\n')

    if [ -z "$add_txn" ]; then
        echo "FAIL: file not in current snapshot"
        return 1
    fi

    local i
    for (( i = 0; i < expect_chunks; i++ )); do
        local hex_out
        hex_out=$(duckdb -noheader -csv -c "
${preamble}
SELECT hex(chunk_data)
FROM read_parquet('${glob}', hive_partitioning=true)
WHERE partition_kind = 'data'
  AND file_action    = 'add'
  AND file_path      = '${file_path}'
  AND txn_seq        = ${add_txn}
  AND chunk_id       = ${i};
" 2>/dev/null | tr -d ' \r\n')

        if [ -z "$hex_out" ]; then
            echo "FAIL: missing chunk ${i}"
            return 1
        fi

        printf "%s" "$hex_out" | xxd -r -p >> "$out_file"
    done

    local actual_size
    actual_size=$(wc -c < "$out_file" | tr -d ' ')
    if [ "$actual_size" != "$expect_size" ]; then
        echo "FAIL: size mismatch (expected $expect_size, got $actual_size)"
        return 1
    fi

    echo "OK"
    return 0
}

cmd_extract() {
    local backup_path="$1"
    local pattern="$2"
    local out_dir="${3:-./}"

    if [ -z "$pattern" ]; then
        log_error "extract requires a pattern (use '%' to match everything)"
        return 1
    fi

    check_xxd
    mkdir -p "$out_dir"

    local preamble
    preamble=$(build_duckdb_preamble "$backup_path")
    local glob
    glob=$(data_glob "$backup_path")

    log_info "Extracting files matching: $pattern"
    log_info "Output directory: $out_dir"
    echo ""

    local list_tmp
    list_tmp=$(mktemp)
    trap "rm -f '$list_tmp'" RETURN

    duckdb -noheader -csv -c "
${preamble}
$(snapshot_cte "$glob")
SELECT file_path, file_size, chunk_count, hex(file_blake3)
FROM snapshot
WHERE file_path LIKE '${pattern}'
ORDER BY file_path;
" 2>/dev/null > "$list_tmp"

    if [ ! -s "$list_tmp" ]; then
        log_warn "No files match pattern: $pattern"
        return 0
    fi

    local match_count
    match_count=$(wc -l < "$list_tmp" | tr -d ' ')
    log_info "Found $match_count matching files"
    echo ""

    local ok=0 fail=0 verify_ok=0 verify_fail=0
    local have_b3sum=0
    if command -v b3sum &>/dev/null; then
        have_b3sum=1
    fi

    while IFS=',' read -r file_path file_size chunk_count blake3_hex; do
        [ -z "$file_path" ] && continue

        local safe_name="${file_path//\//_}"
        safe_name="${safe_name//=/_}"
        local out_file="${out_dir%/}/${safe_name}"

        local result
        result=$(extract_one_file "$preamble" "$glob" "$file_path" "$out_file" "$file_size" "$chunk_count")

        if [ "$result" = "OK" ]; then
            log_success "$file_path  ($file_size bytes, $chunk_count chunks) -> $out_file"
            ok=$((ok + 1))

            if [ "$have_b3sum" = 1 ] && [ -n "$blake3_hex" ]; then
                local actual_hash
                actual_hash=$(b3sum "$out_file" | cut -d' ' -f1)
                local expected_hash
                expected_hash=$(echo "$blake3_hex" | tr '[:upper:]' '[:lower:]')
                if [ "$actual_hash" = "$expected_hash" ]; then
                    verify_ok=$((verify_ok + 1))
                else
                    log_warn "BLAKE3 mismatch for $file_path"
                    log_warn "  expected: $expected_hash"
                    log_warn "  actual:   $actual_hash"
                    verify_fail=$((verify_fail + 1))
                fi
            fi
        else
            log_error "$file_path -- $result"
            fail=$((fail + 1))
        fi
    done < "$list_tmp"

    echo ""
    log_info "Extracted $ok files to $out_dir"
    if [ "$fail" -gt 0 ]; then
        log_error "$fail file(s) failed to extract"
    fi
    if [ "$have_b3sum" = 1 ]; then
        log_info "BLAKE3 verified: $verify_ok ok, $verify_fail mismatched"
    fi
    if [ "$fail" -gt 0 ] || [ "$verify_fail" -gt 0 ]; then
        return 1
    fi
    return 0
}

cmd_verify() {
    local backup_path="$1"
    local pattern="${2:-%}"

    if ! command -v b3sum &>/dev/null; then
        log_error "b3sum is required for verify"
        return 1
    fi
    check_xxd

    local preamble
    preamble=$(build_duckdb_preamble "$backup_path")
    local glob
    glob=$(data_glob "$backup_path")

    log_info "Verifying current snapshot files matching: $pattern"
    echo ""

    local list_tmp tmpfile
    list_tmp=$(mktemp)
    tmpfile=$(mktemp)
    trap "rm -f '$list_tmp' '$tmpfile'" RETURN

    duckdb -noheader -csv -c "
${preamble}
$(snapshot_cte "$glob")
SELECT file_path, file_size, chunk_count, hex(file_blake3)
FROM snapshot
WHERE file_path LIKE '${pattern}'
ORDER BY file_path;
" 2>/dev/null > "$list_tmp"

    if [ ! -s "$list_tmp" ]; then
        log_warn "No files match pattern: $pattern"
        return 0
    fi

    local total=0 ok=0 bad=0 extract_fail=0

    while IFS=',' read -r file_path file_size chunk_count blake3_hex; do
        [ -z "$file_path" ] && continue
        total=$((total + 1))

        echo -n "  $file_path ... "

        rm -f "$tmpfile"
        local result
        result=$(extract_one_file "$preamble" "$glob" "$file_path" "$tmpfile" "$file_size" "$chunk_count")

        if [ "$result" != "OK" ]; then
            echo "${RED}EXTRACT FAILED${NC} ($result)"
            extract_fail=$((extract_fail + 1))
            continue
        fi

        local actual_hash
        actual_hash=$(b3sum "$tmpfile" | cut -d' ' -f1)
        local expected_hash
        expected_hash=$(echo "$blake3_hex" | tr '[:upper:]' '[:lower:]')

        if [ "$actual_hash" = "$expected_hash" ]; then
            echo "${GREEN}OK${NC}"
            ok=$((ok + 1))
        else
            echo "${RED}MISMATCH${NC}"
            echo "    expected: $expected_hash"
            echo "    actual:   $actual_hash"
            bad=$((bad + 1))
        fi
    done < "$list_tmp"

    echo ""
    echo "=== Verification summary ==="
    echo "Total checked:     $total"
    echo "Verified:          $ok"
    echo "Mismatched:        $bad"
    echo "Extract failed:    $extract_fail"

    if [ "$bad" -gt 0 ] || [ "$extract_fail" -gt 0 ]; then
        return 1
    fi
    return 0
}

cmd_export_all() {
    local backup_path="$1"
    local out_dir="${2:-}"

    if [ -z "$out_dir" ]; then
        log_error "export-all requires an output directory"
        echo "Usage: $SCRIPT_NAME $backup_path export-all <out-dir>"
        return 1
    fi

    cmd_extract "$backup_path" "%" "$out_dir"
}

#############################
# MAIN
#############################

main() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)    usage ;;
            -v|--version) echo "$SCRIPT_NAME v$VERSION"; exit 0 ;;
            -*) log_error "Unknown option: $1"; exit 1 ;;
            *)  break ;;
        esac
    done

    if [ $# -lt 2 ]; then
        log_error "Missing arguments"
        echo "Usage: $SCRIPT_NAME <backup-path> <command> [args...]"
        echo "Use --help for more information"
        exit 1
    fi

    local backup_path="$1"
    local command="$2"
    shift 2

    if [[ "$backup_path" != s3://* ]] && [[ "$backup_path" != file://* ]]; then
        if [ ! -d "$backup_path" ]; then
            log_error "Backup directory not found: $backup_path"
            exit 1
        fi
    fi

    check_duckdb

    case "$command" in
        list)       cmd_list "$backup_path" ;;
        info)       cmd_info "$backup_path" ;;
        extract)    cmd_extract "$backup_path" "$@" ;;
        verify)     cmd_verify  "$backup_path" "$@" ;;
        export-all) cmd_export_all "$backup_path" "$@" ;;
        *)
            log_error "Unknown command: $command"
            echo "Use --help for usage information"
            exit 1
            ;;
    esac
}

main "$@"
