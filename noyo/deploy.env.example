# Noyo site config
#
# Copy this to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
#
# deploy.env is gitignored — credentials stay local.

# HydroVu API credentials (or source from ~/.zshrc.private)
# HYDRO_KEY_ID=
# HYDRO_KEY_VALUE=

# S3 backup (dev MinIO — change for production)
S3_URL=s3://duckpond-dev
S3_ENDPOINT=http://watershop.casparwater.us:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
