# Cross-pond import config
#
# Copy this to deploy.env and fill in your values:
#   cp deploy.env.example deploy.env
#
# deploy.env is gitignored — credentials stay local.

# S3/MinIO endpoint (shared by all source buckets)
S3_ENDPOINT=http://watershop.casparwater.us:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ALLOW_HTTP=true

# Source pond backup buckets
NOYO_S3_URL=s3://duckpond-dev
SEPTIC_S3_URL=s3://septic-dev
WATER_S3_URL=s3://water-dev
